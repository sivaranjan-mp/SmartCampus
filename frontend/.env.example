# Local development (default — talks to a backend running on your machine)
# VITE_API_BASE_URL=http://localhost:8080/api

# Production — point this at your deployed backend before running `npm run build`.
# Vite inlines this value at BUILD time, not runtime, so you must rebuild
# after changing it.
VITE_API_BASE_URL=https://your-backend-domain.com/api
VITE_APP_NAME=SmartCampus
